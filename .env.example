# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.

# Production site URL — used for metadata canonical, OpenGraph, sitemap & robots.
NEXT_PUBLIC_SITE_URL=https://firasperfume.com

# WhatsApp order number (digits only, incl. country code) — used by the mini-cart CTA.
NEXT_PUBLIC_WHATSAPP_NUMBER=97477833024

# OPTIONAL — "Inspired by the Greats" brand logos.
# Leave blank to use Google's no-key logo CDN (favicon-quality marks).
# Set a free Brandfetch client ID (https://brandfetch.com/developers) for crisp,
# full-colour brand logos. NEXT_PUBLIC_ prefix is required (used in the browser).
NEXT_PUBLIC_BRANDFETCH_CLIENT_ID=
